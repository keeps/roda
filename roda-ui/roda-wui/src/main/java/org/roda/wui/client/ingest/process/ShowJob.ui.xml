<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder"
             xmlns:g="urn:import:com.google.gwt.user.client.ui"
             xmlns:labels="urn:import:org.roda.wui.client.common.labels"
             xmlns:common="urn:import:org.roda.wui.client.common">

    <g:FocusPanel ui:field="keyboardFocus">
        <g:FlowPanel styleName="browse browse_aip wui-job" addStyleNames="wrapper skip_padding">
            <common:NavigationToolbar ui:field="navigationToolbar"/>

            <common:JobActionsToolbar ui:field="actionsToolbar"/>

            <g:FlowPanel addStyleNames="row full_width skip_padding" ui:field="center">
                <g:FlowPanel addStyleNames="col_12 content">
                    <g:FlowPanel addStyleNames="upperContent">
                        <common:TitlePanel ui:field="title"/>

                        <g:FlowPanel ui:field="content">
                            <g:FlowPanel ui:field="informationPanel" />
                            <g:FlowPanel ui:field="pluginParametersPanel" />
                        </g:FlowPanel>
                    </g:FlowPanel>
                    <g:FlowPanel addStyleNames="lowerContent">
                        <labels:Header ui:field="header"/>
                        <g:FlowPanel ui:field="lowerContent" />
                    </g:FlowPanel>
                </g:FlowPanel>
            </g:FlowPanel>
        </g:FlowPanel>
    </g:FocusPanel>
</ui:UiBinder>