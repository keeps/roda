<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder" xmlns:g="urn:import:com.google.gwt.user.client.ui"
             xmlns:common="urn:import:org.roda.wui.client.common">

    <ui:with field='messages' type='config.i18n.client.ClientMessages'/>

    <g:FlowPanel styleName="descriptiveMetadataTabContainer roda6CardWithHeader">
        <g:FlowPanel styleName="cardHeader" ui:field="header">
            <common:ActionsToolbar ui:field="riskActionsPanel"/>
        </g:FlowPanel>
        <g:FlowPanel styleName="cardBody">
            <g:FlowPanel addStyleNames="risk-details-sections">
                <g:FlowPanel addStyleNames="risk-details-section">
                    <g:FlowPanel ui:field="detailsPanel" addStyleNames="descriptiveMetadata"/>
                </g:FlowPanel>

                <g:FlowPanel addStyleNames="risk-details-section">
                    <g:FlowPanel addStyleNames="risk-details-section-header">
                        <g:HTML styleName="form-separator">
                            <ui:text from='{messages.riskPreMitigation}'/>
                        </g:HTML>
                    </g:FlowPanel>
                    <g:FlowPanel ui:field="preMitigationPanel" addStyleNames="descriptiveMetadata"/>
                </g:FlowPanel>

                <g:FlowPanel addStyleNames="risk-details-section">
                    <g:FlowPanel addStyleNames="risk-details-section-header">
                        <g:HTML styleName="form-separator">
                            <ui:text from='{messages.riskMitigation}'/>
                        </g:HTML>
                    </g:FlowPanel>
                    <g:FlowPanel ui:field="mitigationPanel" addStyleNames="descriptiveMetadata"/>
                </g:FlowPanel>

                <g:FlowPanel addStyleNames="risk-details-section">
                    <g:FlowPanel addStyleNames="risk-details-section-header">
                        <g:HTML styleName="form-separator">
                            <ui:text from='{messages.riskPostMitigation}'/>
                        </g:HTML>
                    </g:FlowPanel>
                    <g:FlowPanel ui:field="postMitigationPanel" addStyleNames="descriptiveMetadata"/>
                </g:FlowPanel>

            </g:FlowPanel>
        </g:FlowPanel>
    </g:FlowPanel>
</ui:UiBinder>
