        <g:FlowPanel addStyleNames="cardBody">
            <g:FlowPanel addStyleNames="row full_width skip_padding">
                <g:FlowPanel ui:field="detailsPanel"/>
            </g:FlowPanel>
        </g:FlowPanel>
    </g:FlowPanel>
</ui:UiBinder>