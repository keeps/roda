<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder" xmlns:g="urn:import:com.google.gwt.user.client.ui"
             xmlns:labels="urn:import:org.roda.wui.client.common.labels">

    <ui:with field='messages' type='config.i18n.client.ClientMessages'/>

    <g:FlowPanel addStyleNames="row full_width">
        <g:FlowPanel addStyleNames="content">
            <g:FlowPanel addStyleNames="page-description" ui:field="permissionsDescription"/>
            <labels:Header ui:field="permissionsTitle"/>
            <g:Label styleName="info-empty" ui:field="permissionsEmpty"/>
            <g:FlowPanel ui:field="permissionsPanel" addStyleNames="plugin-box-padding"/>
        </g:FlowPanel>
    </g:FlowPanel>
</ui:UiBinder>