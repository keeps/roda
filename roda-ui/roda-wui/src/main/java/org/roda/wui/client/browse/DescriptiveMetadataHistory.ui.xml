<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder" xmlns:g="urn:import:com.google.gwt.user.client.ui"
             xmlns:common="urn:import:org.roda.wui.client.common">

    <ui:with field='messages' type='config.i18n.client.ClientMessages'/>

    <g:FocusPanel ui:field="keyboardFocus">
        <g:FlowPanel styleName="browse wui-browse-metadata-descriptive-versions" addStyleNames="wrapper skip_padding">
            <common:NavigationToolbar ui:field="navigationToolbar"/>
            <common:ActionsToolbar ui:field="actionsToolbar"/>
            <g:FlowPanel addStyleNames="row full_width skip_padding">
                <g:FlowPanel addStyleNames="col_12 content">
                    <common:TitlePanel ui:field="title"/>
                    <g:FlowPanel addStyleNames="history-master-detail-layout mb-20">
                        <g:FlowPanel addStyleNames="history-timeline-sidebar roda6Card">
                            <g:Label addStyleNames="history-timeline-title mb-16">
                                <ui:text from="{messages.descriptiveMetadataHistoryVersionsTitle}"/>
                            </g:Label>
                            <g:FlowPanel ui:field="radioContainer" addStyleNames="versions-timeline"/>
                        </g:FlowPanel>
                        <g:FlowPanel addStyleNames="history-content-area roda6Card">
                            <g:FlowPanel ui:field="versionActionsPanel" addStyleNames="alignButtonsPanel mb-16"/>
                            <g:SimplePanel ui:field="tabsContainer"/>
                        </g:FlowPanel>
                    </g:FlowPanel>
                </g:FlowPanel>
            </g:FlowPanel>
        </g:FlowPanel>
    </g:FocusPanel>
</ui:UiBinder>