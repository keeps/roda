<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder" xmlns:g="urn:import:com.google.gwt.user.client.ui"
             xmlns:tab="urn:import:org.roda.wui.client.browse.tabs" xmlns:common="urn:import:org.roda.wui.client.common"
>

    <ui:with field='messages' type='config.i18n.client.ClientMessages'/>
    <g:FocusPanel ui:field="keyboardFocus">
        <g:FlowPanel styleName="wui-risk-register browse" addStyleNames="wrapper skip_padding">
            <common:NavigationToolbar ui:field="navigationToolbar"/>
            <common:BrowseRiskActionsToolbar ui:field="actionsToolbar" label="{messages.showRiskTitle}"/>
            <g:FlowPanel addStyleNames="row full_width skip_padding">
                <g:FlowPanel addStyleNames="col_12 content">
                    <common:TitlePanel ui:field="title" text="{messages.showRiskTitle}" iconClass="IndexedRisk"/>
                    <tab:BrowseRiskTabs ui:field="riskTabs"/>
                </g:FlowPanel>
            </g:FlowPanel>
        </g:FlowPanel>
    </g:FocusPanel>
</ui:UiBinder>
