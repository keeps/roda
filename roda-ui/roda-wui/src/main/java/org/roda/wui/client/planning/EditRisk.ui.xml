<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder" xmlns:g="urn:import:com.google.gwt.user.client.ui"
             xmlns:u="urn:import:org.roda.wui.client.planning" xmlns:common="urn:import:org.roda.wui.client.common">

    <ui:with field='messages' type='config.i18n.client.ClientMessages'/>

    <g:FlowPanel styleName="wui-dialog-layout wui-dialog-layout-risk">
        <g:ScrollPanel styleName="wui-dialog-scrollable-content">
            <u:RiskDataPanel ui:field="riskDataPanel"/>
        </g:ScrollPanel>
        <g:FlowPanel addStyleNames="risk-edit-dialog-footer">
            <g:Button addStyleNames="btn btn-link" ui:field="buttonCancel">
                <ui:text from='{messages.cancelButton}'/>
            </g:Button>
            <g:Button addStyleNames="pull-right btn btn-play" ui:field="buttonApply">
                <ui:text from='{messages.saveButton}'/>
            </g:Button>
        </g:FlowPanel>
    </g:FlowPanel>
</ui:UiBinder>
